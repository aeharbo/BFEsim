Cell[CellGroupData[{

Cell["4. Effective Local Hamiltonian Terms", "Section",ExpressionUUID->"2740d30b-6277-4f79-893d-6e93192dd720"],

Cell["\<\
These functions define the local effective Hamiltonian landscape. We do not \
diagonalize a full quantum Hamiltonian at each step. Instead, we use a \
stochastic classical reduction whose transition probabilities are biased by \
Hubbard/Anderson-like energy terms.\
\>", "Text",ExpressionUUID->"a23c9728-d5e4-4770-a4e6-609c09d6eb47"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Softened", " ", "distance", " ", "avoids", " ", "Coulomb", " ", 
    "divergences", " ", "at", " ", "zero", " ", 
    RowBox[{"separation", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"softDistanceUm", "[", 
      RowBox[{"r1_", ",", " ", "r2_", ",", " ", 
       RowBox[{"softening_", ":", " ", "softeningLengthUm"}]}], "]"}], " ", ":=",
      " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r1", " ", "-", " ", "r2"}], ")"}], "^", "2"}], "]"}], " ", 
       "+", " ", 
       RowBox[{"softening", "^", "2"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"H_field", " ", "+", " ", 
      RowBox[{"H_site", ":", " ", 
       RowBox[{"attraction", " ", "toward", " ", "collection", " ", 
        RowBox[{"implants", ".", " ", "For"}], " ", "holes"}]}]}], ",", " ", 
     RowBox[{"lower", " ", "energy", " ", "means", " ", "more", " ", 
      RowBox[{"favorable", "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
