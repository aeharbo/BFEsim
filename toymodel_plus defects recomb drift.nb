   RowBox[{
    RowBox[{"defectLabels", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\"\<D\>\"", " ", "<>", " ", 
         RowBox[{"ToString", "[", "#", "]"}]}], " ", "&"}], ")"}], " ", "/@", 
      " ", "defectIDs"}]}], ";"}], "\n", 
