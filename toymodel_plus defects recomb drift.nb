          RowBox[{"Return", "[", "position", "]"}]}], "]"}], ";", "\n", "  ", 
        RowBox[{"currentEnergy", " ", "=", " ", 
         RowBox[{"localEffectiveSiteEnergyEV", "[", 
          RowBox[{
          "position", ",", " ", "anodeAssociation", ",", " ", "defects"}], 
          "]"}]}], ";", "\n", "  ", 
        RowBox[{"neighborEnergies", " ", "=", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"localEffectiveSiteEnergyEV", "[", 
            RowBox[{"#", ",", " ", "anodeAssociation", ",", " ", "defects"}], 
            "]"}], " ", "&"}], " ", "/@", " ", "neighbors"}]}], ";", "\n", 
        "  ", 
        RowBox[{"weights", " ", "=", " ", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "nearestNeighborHoppingTemperatureFactor"}], " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"neighborEnergies", " ", "-", " ", "currentEnergy"}], 
             ")"}], "/", "thermalEnergyEV"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"RandomChoice", "[", 
         RowBox[{"weights", " ", "->", " ", "neighbors"}], "]"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"nearestAnodeWithinCollectionRadius", "[", 
      RowBox[{"position_", ",", " ", "anodeAssociation_Association"}], "]"}], 
     " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "distances", "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"distances", " ", "=", " ", 
         RowBox[{"AssociationMap", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"softDistanceUm", "[", 
             RowBox[{"position", ",", " ", 
              RowBox[{
               RowBox[{"anodeAssociation", "[", "#", "]"}], "[", 
               "\"\<PositionUm\>\"", "]"}], ",", " ", "0.0"}], "]"}], " ", 
            "&"}], ",", " ", 
           RowBox[{"Keys", "[", "anodeAssociation", "]"}]}], "]"}]}], ";", 
        "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Min", "[", 
            RowBox[{"Values", "[", "distances", "]"}], "]"}], " ", "<=", " ", 
           "collectionRadiusUm"}], ",", " ", 
          RowBox[{"First", "@", 
           RowBox[{"Keys", "@", 
            RowBox[{"MinimalBy", "[", 
             RowBox[{"distances", ",", " ", "Identity"}], "]"}]}]}], ",", " ",
           "None"}], "]"}]}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"captureProbabilityForDefect", "[", 
      RowBox[{"position_", ",", " ", "defect_Association"}], "]"}], " ", ":=",
      " ", 
     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "distance", ",", " ", "spatialFactor", ",", " ", "occupancyPenalty", 
         ",", " ", "energyFactor"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"distance", " ", "=", " ", 
         RowBox[{"softDistanceUm", "[", 
          RowBox[{"position", ",", " ", 
           RowBox[{"defect", "[", "\"\<PositionUm\>\"", "]"}], ",", " ", 
           "0.0"}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"spatialFactor", " ", "=", " ", 
         RowBox[{"Exp", "[", 
          RowBox[{"-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"distance", "/", 
              RowBox[{"defect", "[", "\"\<CaptureRadiusUm\>\"", "]"}]}], 
             ")"}], "^", "2"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"occupancyPenalty", " ", "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"defect", "[", "\"\<Occupancy\>\"", "]"}], " ", ">=", " ",
             "2"}], ",", " ", "0", ",", " ", 
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"1", " ", "+", " ", 
              RowBox[{
               RowBox[{"defect", "[", "\"\<Occupancy\>\"", "]"}], " ", 
               RowBox[{
                RowBox[{"defect", "[", "\"\<HubbardUEV\>\"", "]"}], "/", 
                "thermalEnergyEV"}]}]}], ")"}]}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"energyFactor", " ", "=", " ", 
