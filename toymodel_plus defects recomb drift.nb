Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"anodeLabels", " ", "=", " ", 
    RowBox[{"Keys", "[", 
     RowBox[{
      RowBox[{"stateHistory", "[", 
       RowBox[{"First", "[", "storedSteps", "]"}], "]"}], "[", 
      "\"\<Anodes\>\"", "]"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"anodeCountsByStep", " ", "=", "\n", "  ", 
    RowBox[{"AssociationMap", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"step", ",", "\n", "      ", 
        RowBox[{"Association", " ", "@", " ", 
         RowBox[{"KeyValueMap", "[", "\n", "        ", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"anodeLabel", ",", " ", "anodeData"}], "}"}], ",", "\n",
              "          ", 
             RowBox[{"anodeLabel", " ", "->", " ", 
              RowBox[{
              "anodeData", "[", "\"\<CollectedHoleCount\>\"", "]"}]}]}], "\n",
             "        ", "]"}], ",", "\n", "        ", 
           RowBox[{
            RowBox[{"stateHistory", "[", "step", "]"}], "[", "\"\<Anodes\>\"",
             "]"}]}], "\n", "      ", "]"}]}]}], "\n", "    ", "]"}], ",", 
      "\n", "    ", "storedSteps"}], "\n", "  ", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"landingProbabilityByStep", " ", "=", "\n", "  ", 
    RowBox[{"AssociationMap", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"step", ",", "\n", "      ", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"counts", ",", " ", "totalCollected"}], "}"}], ",", "\n", 
          "        ", 
          RowBox[{
           RowBox[{"counts", " ", "=", " ", 
            RowBox[{"anodeCountsByStep", "[", "step", "]"}]}], ";", "\n", 
           "        ", 
           RowBox[{"totalCollected", " ", "=", " ", 
            RowBox[{"Total", "[", 
             RowBox[{"Values", "[", "counts", "]"}], "]"}]}], ";", "\n", "\n",
            "        ", 
           RowBox[{"AssociationMap", "[", "\n", "          ", 
            RowBox[{
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"totalCollected", " ", "==", " ", "0"}], ",", " ", 
                "0", ",", " ", 
                RowBox[{"#", "/", "totalCollected"}]}], "]"}], " ", "&"}], 
             ",", "\n", "          ", "counts"}], "\n", "        ", "]"}]}]}],
          "\n", "      ", "]"}]}], "\n", "    ", "]"}], ",", "\n", "    ", 
      "storedSteps"}], "\n", "  ", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"ListLinePlot", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"#", ",", " ", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"Values", "[", 
           RowBox[{"anodeCountsByStep", "[", "#", "]"}], "]"}], "]"}], "/", 
         "numberOfMobileHoles"}]}], "}"}], " ", "&"}], " ", "/@", " ", 
     "storedSteps"}], ")"}], ",", "\n", "  ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
     "\"\<MC step\>\"", ",", " ", "\"\<Toy QE = collected / generated\>\""}], 
     "}"}]}], ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<Toy quantum efficiency vs time\>\""}], 
   ",", "\n", "  ", 
   RowBox[{"PlotRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "Large"}], ",", "\n", "  ", 
   RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}]}], "\n", 
  "]"}]}], "Code",
