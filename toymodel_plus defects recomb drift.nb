            RowBox[{"hole", "[", "\"\<State\>\"", "]"}], " ", "=!=", " ", 
            "\"\<Trapped\>\""}], " ", "||", " ", 
           RowBox[{
            RowBox[{"RandomReal", "[", "]"}], " ", ">", " ", 
            "defectRecombinationProbability"}]}], ",", " ", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", " ", "defects"}], "}"}], "]"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"defectIndex", " ", "=", " ", 
         RowBox[{"FirstPosition", "[", 
          RowBox[{
           RowBox[{"defects", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "\"\<DefectID\>\""}], "]"}], "]"}], ",",
            " ", 
           RowBox[{"hole", "[", "\"\<CapturedByDefect\>\"", "]"}], ",", " ", 
