          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", "updatedAnodes"}], "}"}], "]"}]}], "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"label", "=", 
         RowBox[{"nearestAnodeWithinCollectionRadius", "[", 
