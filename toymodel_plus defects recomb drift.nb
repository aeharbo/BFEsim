          " ", "&"}], " ", "/@", "\n", "      ", 
         RowBox[{"Select", "[", 
          RowBox[{"holes", ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", "\"\<State\>\"", "]"}], " ", "===", " ", 
             "\"\<Mobile\>\""}], " ", "&"}]}], "]"}]}], ")"}]}], ";", "\n", 
      "\n", "  ", 
      RowBox[{"trappedHolePoints", " ", "=", "\n", "    ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Orange", ",", " ", 
            RowBox[{"PointSize", "[", "0.018", "]"}], ",", " ", 
            RowBox[{"Point", "[", 
             RowBox[{"#", "[", "\"\<PositionUm\>\"", "]"}], "]"}]}], "}"}], 
