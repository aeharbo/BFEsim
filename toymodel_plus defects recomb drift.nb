          RowBox[{"MissingQ", "[", "defectIndex", "]"}], ",", " ", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", " ", "defects"}], "}"}], "]"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"defectIndex", " ", "=", " ", 
         RowBox[{"First", "[", "defectIndex", "]"}]}], ";", "\n", "  ", 
        RowBox[{"{", "\n", "    ", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{"hole", ",", " ", 
            RowBox[{"<|", 
             RowBox[{
              RowBox[{"\"\<State\>\"", " ", "->", " ", "\"\<Recombined\>\""}],
               ",", " ", 
              RowBox[{"\"\<CapturedByDefect\>\"", " ", "->", " ", "None"}]}], 
             "|>"}]}], "]"}], ",", "\n", "    ", 
          RowBox[{"ReplacePart", "[", 
           RowBox[{"defects", ",", " ", 
            RowBox[{"defectIndex", " ", "->", " ", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"defects", "[", 
                RowBox[{"[", "defectIndex", "]"}], "]"}], ",", " ", 
               RowBox[{"<|", "\n", "      ", 
                RowBox[{
                 RowBox[{"\"\<Occupancy\>\"", " ", "->", " ", 
                  RowBox[{"Max", "[", 
                   RowBox[{"0", ",", " ", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"defects", "[", 
                    RowBox[{"[", "defectIndex", "]"}], "]"}], "[", 
                    "\"\<Occupancy\>\"", "]"}], " ", "-", " ", "1"}]}], 
