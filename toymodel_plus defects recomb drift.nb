           RowBox[{"-", 
            RowBox[{"Max", "[", 
             RowBox[{
              RowBox[{"defect", "[", "\"\<DefectEnergyEV\>\"", "]"}], ",", 
              " ", "0"}], "]"}]}], "/", "thermalEnergyEV"}], "]"}]}], ";", 
        "\n", "  ", 
        RowBox[{"Min", "[", 
         RowBox[{"1", ",", " ", 
          RowBox[{
          "defectCaptureBaseProbability", " ", "spatialFactor", " ", 
           "occupancyPenalty", " ", "energyFactor"}]}], "]"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"attemptDefectCapture", "[", 
