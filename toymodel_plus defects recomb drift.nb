                 "\n", "    ", "|>"}]}], "]"}]}]}], "]"}]}], "\n", "  ", 
         "}"}]}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"attemptCollection", "[", 
      RowBox[{"hole_", ",", "anodeAssociation_Association"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"label", ",", 
         RowBox[{"updatedAnodes", "=", "anodeAssociation"}]}], "}"}], ",", 
