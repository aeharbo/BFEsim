          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", " ", "defects"}], "}"}], "]"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"chosenIndex", " ", "=", " ", 
         RowBox[{"RandomChoice", "[", 
          RowBox[{"probs", " ", "->", " ", 
           RowBox[{"Range", "[", 
            RowBox[{"Length", "[", "defects", "]"}], "]"}]}], "]"}]}], ";", 
        "\n", "  ", 
        RowBox[{"{", "\n", "    ", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{"hole", ",", " ", 
            RowBox[{"<|", 
             RowBox[{
              RowBox[{"\"\<State\>\"", " ", "->", " ", "\"\<Trapped\>\""}], 
              ",", " ", 
              RowBox[{"\"\<CapturedByDefect\>\"", " ", "->", " ", 
               RowBox[{
                RowBox[{"defects", "[", 
                 RowBox[{"[", "chosenIndex", "]"}], "]"}], "[", 
                "\"\<DefectID\>\"", "]"}]}]}], "|>"}]}], "]"}], ",", "\n", 
          "    ", 
          RowBox[{"ReplacePart", "[", 
           RowBox[{"defects", ",", " ", 
            RowBox[{"chosenIndex", " ", "->", " ", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"defects", "[", 
                RowBox[{"[", "chosenIndex", "]"}], "]"}], ",", " ", 
               RowBox[{"<|", "\n", "      ", 
                RowBox[{
                 RowBox[{"\"\<Occupancy\>\"", " ", "->", " ", 
