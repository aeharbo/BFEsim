Notebook[{

Cell[CellGroupData[{
Cell["\<\
Extended Stochastic Many-Body Transport Toy Model for HgCdTe NIR Detector \
Pixels\
\>", "Title",ExpressionUUID->"fddf1c42-5c6e-4260-90d4-0eb26aea20b0"],

Cell["\<\
This notebook instantiates a Hubbard/Anderson-inspired stochastic transport \
model. Holes move on a 3D lattice, interact with dynamically occupied defect \
orbitals, and collect at p+ anodes. The local effective Hamiltonian changes \
as holes are trapped, emitted, recombined, or collected.\
\>", "Text",ExpressionUUID->"92637479-bcfe-487b-80e4-dabcb58f053b"],

Cell[CellGroupData[{

Cell["1. Clear State and Global Parameters", "Section",ExpressionUUID->"5d7473f5-6093-4ad7-a42a-a3124342e8f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}]], "Code",
 CellChangeTimes->{3.9877739738965244`*^9},
 CellLabel->
  "In[676]:=",ExpressionUUID->"c41b7cef-a714-4f70-9d01-a1da3453b7a3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Geometry", " ", "in", " ", 
    RowBox[{"microns", ".", " ", "The"}], " ", "volume", " ", "is", " ", "a", 
    " ", "small", " ", "3", " ", "x", " ", "3", " ", "anode", " ", 
    RowBox[{"supercell", "."}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"pixelPitchUm", " ", "=", " ", "10.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"numberOfPixelsX", " ", "=", " ", "3"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"numberOfPixelsY", " ", "=", " ", "3"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"depletionThicknessUm", " ", "=", " ", "5.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"latticeSpacingUm", " ", "=", " ", "0.1"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"xCoordinatesUm", " ", "=", " ", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"numberOfPixelsX", " ", "pixelPitchUm"}], ",", " ", 
     "latticeSpacingUm"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"yCoordinatesUm", " ", "=", " ", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"numberOfPixelsY", " ", "pixelPitchUm"}], ",", " ", 
     "latticeSpacingUm"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"zCoordinatesUm", " ", "=", " ", 
    RowBox[{"Range", "[", 
     RowBox[{
     "0", ",", " ", "depletionThicknessUm", ",", " ", "latticeSpacingUm"}], 
     "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Thermal", " ", "and", " ", "stochastic", " ", "model", " ", 
    RowBox[{"parameters", ".", " ", "Energies"}], " ", "are", " ", "toy", " ",
     "eV", " ", 
    RowBox[{"values", "."}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"temperatureK", " ", "=", " ", "89.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"boltzmannEVperK", " ", "=", " ", 
   RowBox[{"8.617333262", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "5"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"thermalEnergyEV", " ", "=", " ", 
   RowBox[{"boltzmannEVperK", " ", "temperatureK"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"numberOfMobileHoles", " ", "=", " ", "90"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"numberOfTransportSteps", " ", "=", " ", "800"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"initialHoleZRangeUm", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"0.0", ",", " ", "1.0"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"collectionRadiusUm", " ", "=", " ", "2.75"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"softeningLengthUm", " ", "=", " ", "0.65"}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Hamiltonian", "-", 
     RowBox[{"like", " ", "energy", " ", 
      RowBox[{"scales", ".", " ", "Parameters"}], " ", "not", " ", "accurate",
       " ", "to", " ", "reality"}]}], ",", " ", "afaik"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
