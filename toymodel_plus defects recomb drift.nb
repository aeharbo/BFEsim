Cell[CellGroupData[{

Cell["2. Lattice, p+ Anodes, and Mobile Hole Ensemble", "Section",ExpressionUUID->"d797f2ca-02ab-452a-afa9-dffb2caa6aad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Each", " ", "lattice", " ", "site", " ", "is", " ", "a", " ", "possible",
      " ", "coarse"}], "-", 
    RowBox[{"grained", " ", "carrier", " ", 
     RowBox[{"location", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"latticeSitesUm", " ", "=", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "xCoordinatesUm"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"y", ",", " ", "yCoordinatesUm"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"z", ",", " ", "zCoordinatesUm"}], "}"}]}], "]"}], ",", " ",
        "2"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"3", " ", "x", " ", "3", " ", "p"}], "+", " ", 
      RowBox[{
      "collection", " ", "implants", " ", "are", " ", "placed", " ", "at", 
       " ", "z"}]}], " ", "=", " ", 
     RowBox[{"depletionThicknessUm", "."}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"anodeLabels", " ", "=", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"\"\<A\>\"", " ", "<>", " ", 
         RowBox[{"ToString", "[", "ix", "]"}], " ", "<>", " ", 
         RowBox[{"ToString", "[", "iy", "]"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"ix", ",", " ", "1", ",", " ", "numberOfPixelsX"}], "}"}], 
        ",", " ", 
        RowBox[{"{", 
         RowBox[{"iy", ",", " ", "1", ",", " ", "numberOfPixelsY"}], "}"}]}], 
       "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"anodePositionsUm", " ", "=", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"ix", " ", "-", " ", "0.5"}], ")"}], " ", 
            "pixelPitchUm"}], ",", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"iy", " ", "-", " ", "0.5"}], ")"}], " ", 
            "pixelPitchUm"}], ",", " ", "depletionThicknessUm"}], "}"}], ",", 
         " ", 
         RowBox[{"{", 
          RowBox[{"ix", ",", " ", "1", ",", " ", "numberOfPixelsX"}], "}"}], 
         ",", " ", 
         RowBox[{"{", 
          RowBox[{"iy", ",", " ", "1", ",", " ", "numberOfPixelsY"}], "}"}]}],
         "]"}], ",", " ", "1"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"createAnodeAssociation", "[", "]"}], " ", ":=", " ", 
     RowBox[{"AssociationThread", "[", "\n", "  ", 
      RowBox[{"anodeLabels", ",", "\n", "  ", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<PositionUm\>\"", " ", "->", " ", "#"}], ",", " ", 
            RowBox[{"\"\<CollectedHoleCount\>\"", " ", "->", " ", "0"}]}], 
           "|>"}], " ", "&"}], ",", " ", "anodePositionsUm"}], "]"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"currentAnodes", " ", "=", " ", 
     RowBox[{"createAnodeAssociation", "[", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Initial", " ", "holes", " ", "are", " ", "generated", " ", "in", " ", 
      "an", " ", "absorption"}], "-", 
     RowBox[{
     "like", " ", "layer", " ", "near", " ", "the", " ", "illuminated", " ", 
      RowBox[{"side", "."}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"createInitialHole", "[", "id_Integer", "]"}], " ", ":=", " ", 
     RowBox[{"<|", "\n", "  ", 
      RowBox[{
       RowBox[{"\"\<HoleID\>\"", " ", "->", " ", "id"}], ",", "\n", "  ", 
       RowBox[{"\"\<PositionUm\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"numberOfPixelsX", " ", "pixelPitchUm"}]}], "}"}], "]"}],
           ",", " ", 
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", " ", 
             RowBox[{"numberOfPixelsY", " ", "pixelPitchUm"}]}], "}"}], "]"}],
           ",", " ", 
          RowBox[{"RandomReal", "[", "initialHoleZRangeUm", "]"}]}], "}"}]}], 
       ",", "\n", "  ", 
       RowBox[{"\"\<State\>\"", " ", "->", " ", "\"\<Mobile\>\""}], ",", "\n",
        "  ", 
       RowBox[{"\"\<CapturedByDefect\>\"", " ", "->", " ", "None"}], ",", 
       "\n", "  ", 
       RowBox[{"\"\<CollectedByAnode\>\"", " ", "->", " ", "None"}], ",", 
       "\n", "  ", 
       RowBox[{"\"\<LifetimeSteps\>\"", " ", "->", " ", "0"}]}], "\n", 
      "|>"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"initialHolePopulation", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"createInitialHole", "[", "id", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"id", ",", " ", "numberOfMobileHoles"}], "}"}]}], "]"}]}], 
    ";"}], "\n"}]}]], "Code",
 CellLabel->
