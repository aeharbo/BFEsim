             "#"}], "]"}], " ", "&"}], " ", "/@", " ", "defects"}]}], ";", 
        "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Total", "[", "probs", "]"}], " ", "<=", " ", "0"}], " ", 
           "||", " ", 
           RowBox[{
            RowBox[{"RandomReal", "[", "]"}], " ", ">", " ", 
