          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", " ", "defects"}], "}"}], "]"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"defectIndex", " ", "=", " ", 
         RowBox[{"FirstPosition", "[", 
          RowBox[{
           RowBox[{"defects", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "\"\<DefectID\>\""}], "]"}], "]"}], ",",
            " ", 
           RowBox[{"hole", "[", "\"\<CapturedByDefect\>\"", "]"}], ",", " ", 
           RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], "]"}]}], ";", 
        "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MissingQ", "[", "defectIndex", "]"}], ",", " ", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", " ", "defects"}], "}"}], "]"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"defectIndex", " ", "=", " ", 
         RowBox[{"First", "[", "defectIndex", "]"}]}], ";", "\n", "  ", 
        RowBox[{"defect", " ", "=", " ", 
         RowBox[{"defects", "[", 
          RowBox[{"[", "defectIndex", "]"}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"emissionProbability", " ", "=", " ", 
         RowBox[{"Min", "[", 
          RowBox[{"1", ",", " ", 
           RowBox[{"defectEmissionBaseProbability", " ", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"defect", "[", "\"\<DefectEnergyEV\>\"", "]"}], "/", 
              "thermalEnergyEV"}], "]"}]}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"RandomReal", "[", "]"}], " ", ">", " ", 
           "emissionProbability"}], ",", " ", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"hole", ",", " ", "defects"}], "}"}], "]"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"emittedPosition", " ", "=", " ", 
         RowBox[{
          RowBox[{"defect", "[", "\"\<PositionUm\>\"", "]"}], " ", "+", " ", 
          RowBox[{"RandomChoice", "[", "neighborDisplacementsUm", "]"}]}]}], 
        ";", "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", " ", 
           RowBox[{"insideSimulationVolumeQ", "[", "emittedPosition", "]"}]}],
           ",", " ", 
          RowBox[{"emittedPosition", " ", "=", " ", 
           RowBox[{"defect", "[", "\"\<PositionUm\>\"", "]"}]}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"{", "\n", "    ", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{"hole", ",", " ", 
            RowBox[{"<|", 
             RowBox[{
              RowBox[{"\"\<State\>\"", " ", "->", " ", "\"\<Mobile\>\""}], 
              ",", " ", 
              RowBox[{
              "\"\<PositionUm\>\"", " ", "->", " ", "emittedPosition"}], ",", 
              " ", 
              RowBox[{"\"\<CapturedByDefect\>\"", " ", "->", " ", "None"}]}], 
             "|>"}]}], "]"}], ",", "\n", "    ", 
          RowBox[{"ReplacePart", "[", 
           RowBox[{"defects", ",", " ", 
            RowBox[{"defectIndex", " ", "->", " ", 
             RowBox[{"Join", "[", 
              RowBox[{"defect", ",", " ", 
               RowBox[{"<|", "\n", "      ", 
                RowBox[{
                 RowBox[{"\"\<Occupancy\>\"", " ", "->", " ", 
                  RowBox[{"Max", "[", 
                   RowBox[{"0", ",", " ", 
                    RowBox[{
                    RowBox[{"defect", "[", "\"\<Occupancy\>\"", "]"}], " ", 
                    "-", " ", "1"}]}], "]"}]}], ",", "\n", "      ", 
                 RowBox[{"\"\<CapturedHoleIDs\>\"", " ", "->", " ", 
                  RowBox[{"DeleteCases", "[", 
                   RowBox[{
                    RowBox[{"defect", "[", "\"\<CapturedHoleIDs\>\"", "]"}], 
                    ",", " ", 
                    RowBox[{"hole", "[", "\"\<HoleID\>\"", "]"}]}], "]"}]}]}],
                 "\n", "    ", "|>"}]}], "]"}]}]}], "]"}]}], "\n", "  ", 
         "}"}]}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"attemptTrapAssistedRecombination", "[", 
      RowBox[{"hole_", ",", " ", "defects_List"}], "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "defectIndex", "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
