 RowBox[{
  RowBox[{"defectCaptureBaseProbability", " ", "=", " ", "0.10"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"defectEmissionBaseProbability", " ", "=", " ", "0.025"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"defectRecombinationProbability", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "4"}]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nearestNeighborHoppingTemperatureFactor", " ", "=", " ", "1.0"}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Drift", " ", "field"}], ",", " ", 
    RowBox[{
    "taken", " ", "form", " ", "Mosby", " ", "et", " ", "al", " ", "2020"}]}],
    " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"driftFieldVperCm", " ", "=", " ", "20.0"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"driftFieldVperUm", "=", 
   RowBox[{"driftFieldVperCm", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"driftEnergyAcrossAbsorberEV", "=", 
   RowBox[{"driftFieldVperUm", "*", "depletionThicknessUm"}]}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Hole", " ", "drift", " ", "energy", " ", 
     RowBox[{"contribution", ".", "Negative"}], " ", "sign", " ", "means", 
     " ", "larger", " ", "z", " ", "is", " ", "energetically", " ", 
     "favorable", " ", "for", " ", "holes"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"i", ".", "e", ".", "drift"}], " ", "toward", " ", "the", " ", 
      "anode", " ", "plane", " ", "at", " ", "z"}], "=", 
     RowBox[{"d", "."}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"holeDriftEnergyEV", "[", "positionUm_", "]"}], ":=", 
    RowBox[{
     RowBox[{"-", "driftFieldVperUm"}], "*", 
     RowBox[{"positionUm", "[", 
      RowBox[{"[", "3", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
