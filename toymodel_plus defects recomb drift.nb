                   RowBox[{
                    RowBox[{"defects", "[", 
                    RowBox[{"[", "chosenIndex", "]"}], "]"}], "[", 
                    "\"\<Occupancy\>\"", "]"}], " ", "+", " ", "1"}]}], ",", 
                 "\n", "      ", 
                 RowBox[{"\"\<CapturedHoleIDs\>\"", " ", "->", " ", 
