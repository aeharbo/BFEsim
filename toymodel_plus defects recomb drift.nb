Cell["8. 3D Visualization Functions", "Section",ExpressionUUID->"d00272e7-2295-4bcc-a58b-5b204d4af7f7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"trajectoryGraphicsForStep", "[", "step_Integer", "]"}], " ", ":=",
    " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", "historyIndex", "}"}], ",", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"historyIndex", " ", "=", " ", 
       RowBox[{"FirstPosition", "[", 
        RowBox[{"storedSteps", ",", " ", "step", ",", " ", 
         RowBox[{"Missing", "[", "\"\<StepNotFound\>\"", "]"}]}], "]"}]}], 
      ";", "\n", "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"MissingQ", "[", "historyIndex", "]"}], ",", " ", 
        RowBox[{"Return", "[", 
         RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\n", "\n", "  ", 
      RowBox[{"historyIndex", " ", "=", " ", 
       RowBox[{"First", "[", "historyIndex", "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"Table", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", "partialTrajectory", "}"}], ",", "\n", "\n", "      ", 
           RowBox[{
            RowBox[{"partialTrajectory", " ", "=", "\n", "        ", 
             RowBox[{"Take", "[", 
              RowBox[{
               RowBox[{"holeTrajectoryByID", "[", 
                RowBox[{"holeIDs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", " ", 
               "historyIndex"}], "]"}]}], ";", "\n", "\n", "      ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Length", "[", "partialTrajectory", "]"}], " ", "<", 
               " ", "2"}], ",", "\n", "        ", "Nothing", ",", "\n", 
              "        ", 
              RowBox[{"With", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"path", " ", "=", " ", "partialTrajectory"}], "}"}], 
                ",", "\n", "          ", 
                RowBox[{"{", "\n", "            ", 
                 RowBox[{"Thick", ",", "\n", "            ", 
                  RowBox[{
                   RowBox[{"ColorData", "[", "\"\<BrightBands\>\"", "]"}], 
                   "[", 
                   RowBox[{"Rescale", "[", 
                    RowBox[{"i", ",", " ", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", " ", 
                    RowBox[{"Length", "[", "holeIDs", "]"}]}], "}"}]}], "]"}],
                    "]"}], ",", "\n", "            ", 
                  RowBox[{"Line", "[", "path", "]"}]}], "\n", "          ", 
                 "}"}]}], "\n", "        ", "]"}]}], "\n", "      ", 
             "]"}]}]}], "\n", "    ", "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"i", ",", " ", 
           RowBox[{"Length", "[", "holeIDs", "]"}]}], "}"}]}], "\n", "  ", 
        "]"}], " ", "/.", " ", 
       RowBox[{"Nothing", " ", "->", " ", 
        RowBox[{"Sequence", "[", "]"}]}]}]}]}], "\n", "]"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
