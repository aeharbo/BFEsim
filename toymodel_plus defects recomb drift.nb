               "\"\<Anodes\>\"", "]"}], "[", "#", "]"}], "[", 
             "\"\<CollectedHoleCount\>\"", "]"}], " ", "&"}], ",", "\n", 
           "      ", "anodeLabels"}], "\n", "    ", "]"}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
