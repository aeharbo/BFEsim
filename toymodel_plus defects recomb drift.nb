Cell[CellGroupData[{

Cell["6. One Full Dynamical Step", "Section",
 CellLabel->"",ExpressionUUID->"9f582f09-f4f4-4a3f-9e3d-0680099f0339"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"advanceOneHole", "[", 
     RowBox[{
     "hole_", ",", " ", "anodeAssociation_Association", ",", " ", 
      "defects_List"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"updatedHole", " ", "=", " ", "hole"}], ",", " ", 
        RowBox[{"updatedAnodes", " ", "=", " ", "anodeAssociation"}], ",", 
        " ", 
        RowBox[{"updatedDefects", " ", "=", " ", "defects"}], ",", " ", 
        "result"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"updatedHole", " ", "=", " ", 
        RowBox[{"Join", "[", 
         RowBox[{"updatedHole", ",", " ", 
          RowBox[{"<|", 
           RowBox[{"\"\<LifetimeSteps\>\"", " ", "->", " ", 
            RowBox[{
             RowBox[{"updatedHole", "[", "\"\<LifetimeSteps\>\"", "]"}], " ", 
             "+", " ", "1"}]}], "|>"}]}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Trapped", " ", "holes", " ", "may", " ", "emit", " ", "back", " ", 
         "to", " ", "mobile", " ", "states", " ", "or", " ", 
         RowBox[{"recombine", "."}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"result", " ", "=", " ", 
        RowBox[{"attemptTrapAssistedRecombination", "[", 
         RowBox[{"updatedHole", ",", " ", "updatedDefects"}], "]"}]}], ";", 
       "\n", "  ", 
       RowBox[{"updatedHole", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", " ", 
       RowBox[{"updatedDefects", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"result", " ", "=", " ", 
        RowBox[{"attemptEmissionFromDefect", "[", 
         RowBox[{"updatedHole", ",", " ", "updatedDefects"}], "]"}]}], ";", 
       "\n", "  ", 
       RowBox[{"updatedHole", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", " ", 
       RowBox[{"updatedDefects", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Mobile", " ", "holes", " ", "hop", " ", "in", " ", "the", " ", 
          "currently", " ", "occupied"}], "-", 
         RowBox[{"defect", " ", "and", " ", "collected"}], "-", 
         RowBox[{"charge", " ", "energy", " ", 
          RowBox[{"landscape", "."}]}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"updatedHole", "[", "\"\<State\>\"", "]"}], " ", "===", 
          " ", "\"\<Mobile\>\""}], ",", "\n", "    ", 
         RowBox[{"updatedHole", " ", "=", " ", 
          RowBox[{"Join", "[", 
           RowBox[{"updatedHole", ",", " ", 
            RowBox[{"<|", 
             RowBox[{"\"\<PositionUm\>\"", " ", "->", " ", 
              RowBox[{"boltzmannBiasedNextPosition", "[", 
               RowBox[{
                RowBox[{"updatedHole", "[", "\"\<PositionUm\>\"", "]"}], ",", 
                " ", "updatedAnodes", ",", " ", "updatedDefects"}], "]"}]}], 
             "|>"}]}], "]"}]}]}], "\n", "  ", "]"}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Mobile", " ", "holes", " ", "may", " ", "get", " ", "captured", " ", 
         "by", " ", "defect", " ", 
         RowBox[{"orbitals", "."}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"result", " ", "=", " ", 
        RowBox[{"attemptDefectCapture", "[", 
         RowBox[{"updatedHole", ",", " ", "updatedDefects"}], "]"}]}], ";", 
       "\n", "  ", 
       RowBox[{"updatedHole", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", " ", 
       RowBox[{"updatedDefects", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Mobile", " ", "holes", " ", "close", " ", "to", " ", "a", " ", 
          "p"}], "+", " ", 
         RowBox[{"implant", " ", "are", " ", 
          RowBox[{"collected", "."}]}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"result", " ", "=", " ", 
        RowBox[{"attemptCollection", "[", 
         RowBox[{"updatedHole", ",", " ", "updatedAnodes"}], "]"}]}], ";", 
       "\n", "  ", 
       RowBox[{"updatedHole", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", " ", 
       RowBox[{"updatedAnodes", " ", "=", " ", 
        RowBox[{"result", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
        "updatedHole", ",", " ", "updatedAnodes", ",", " ", 
         "updatedDefects"}], "}"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"advanceSystemOneStep", "[", 
    RowBox[{
    "holes_List", ",", " ", "anodeAssociation_Association", ",", " ", 
     "defects_List"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"currentHoles", " ", "=", " ", "holes"}], ",", " ", 
