Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"collectionStepByHole", " ", "=", "\n", "  ", 
    RowBox[{"AssociationMap", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"holeID", ",", "\n", "      ", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "firstCollected", "}"}], ",", "\n", "        ", 
          RowBox[{
           RowBox[{"firstCollected", " ", "=", "\n", "          ", 
            RowBox[{"SelectFirst", "[", "\n", "            ", 
             RowBox[{"storedSteps", ",", "\n", "            ", 
              RowBox[{
               RowBox[{"AnyTrue", "[", "\n", "              ", 
                RowBox[{
                 RowBox[{
                  RowBox[{"stateHistory", "[", "#", "]"}], "[", 
                  "\"\<Holes\>\"", "]"}], ",", "\n", "              ", 
                 RowBox[{"Function", "[", 
                  RowBox[{"h", ",", "\n", "                ", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"h", "[", "\"\<HoleID\>\"", "]"}], " ", "===", 
                    " ", "holeID"}], " ", "&&", "\n", "                  ", 
                    RowBox[{
                    RowBox[{"h", "[", "\"\<State\>\"", "]"}], " ", "===", 
                    " ", "\"\<Collected\>\""}]}]}], "\n", "              ", 
                  "]"}]}], "\n", "            ", "]"}], " ", "&"}]}], "\n", 
             "          ", "]"}]}], ";", "\n", "\n", "        ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"MissingQ", "[", "firstCollected", "]"}], ",", " ", 
             RowBox[{"Missing", "[", "\"\<NotCollected\>\"", "]"}], ",", " ", 
             "firstCollected"}], "]"}]}]}], "\n", "      ", "]"}]}], "\n", 
       "    ", "]"}], ",", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{"stateHistory", "[", 
         RowBox[{"First", "[", "storedSteps", "]"}], "]"}], "[", 
        "\"\<Holes\>\"", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "\"\<HoleID\>\""}], "]"}], "]"}]}], "\n", 
     "  ", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"collectedSteps", " ", "=", "\n", "  ", 
