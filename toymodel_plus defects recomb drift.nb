              RowBox[{"\"\<State\>\"", "->", "\"\<Collected\>\""}], ",", 
              RowBox[{"\"\<CollectedByAnode\>\"", "->", "label"}]}], "|>"}]}],
            "]"}], ",", "updatedAnodes"}], "}"}]}]}], "]"}]}], 
    ";"}]}]}]], "Code",
