         "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"step", ",", " ", "availableTransportSteps"}], "}"}]}], "\n", 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stateCountDataset", " ", "=", " ", 
     RowBox[{"Dataset", "[", "stateCountRows", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"anodeLabels", " ", "=", " ", 
     RowBox[{"Keys", "[", 
      RowBox[{
       RowBox[{"stateHistory", "[", 
        RowBox[{"First", "[", "availableTransportSteps", "]"}], "]"}], "[", 
       "\"\<Anodes\>\"", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"anodeCountRows", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
