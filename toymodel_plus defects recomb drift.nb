}, Open  ]],

Cell[CellGroupData[{

Cell["3. Localized Defect Orbitals", "Section",ExpressionUUID->"e15b4eba-af37-4849-9723-622faed7a228"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "A", " ", "defect", " ", "orbital", " ", "has", " ", "a", " ", 
     "localized", " ", "position"}], ",", " ", 
    RowBox[{"an", " ", "energy", " ", "level"}], ",", " ", 
    RowBox[{
     RowBox[{"an", " ", "on"}], "-", 
     RowBox[{"site", " ", "charging", " ", "energy", " ", "U"}]}], ",", "\n", 
    "   ", 
    RowBox[{"a", " ", 
     RowBox[{"hybridization", "/", "capture"}], " ", "radius"}], ",", " ", 
    RowBox[{"and", " ", "a", " ", "stochastic", " ", 
     RowBox[{"occupancy", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"createDefect", "[", 
      RowBox[{
      "id_Integer", ",", " ", "position_", ",", " ", "defectEnergyEV_", ",", 
       " ", "hubbardUEV_", ",", " ", "captureRadiusUm_"}], "]"}], " ", ":=", 
     " ", 
     RowBox[{"<|", "\n", "  ", 
      RowBox[{
       RowBox[{"\"\<DefectID\>\"", " ", "->", " ", "id"}], ",", "\n", "  ", 
       RowBox[{"\"\<PositionUm\>\"", " ", "->", " ", "position"}], ",", "\n", 
       "  ", 
       RowBox[{"\"\<DefectEnergyEV\>\"", " ", "->", " ", "defectEnergyEV"}], 
       ",", "\n", "  ", 
       RowBox[{"\"\<HubbardUEV\>\"", " ", "->", " ", "hubbardUEV"}], ",", 
       "\n", "  ", 
       RowBox[{"\"\<CaptureRadiusUm\>\"", " ", "->", " ", "captureRadiusUm"}],
        ",", "\n", "  ", 
       RowBox[{"\"\<Occupancy\>\"", " ", "->", " ", "0"}], ",", "\n", "  ", 
       RowBox[{"\"\<CapturedHoleIDs\>\"", " ", "->", " ", 
        RowBox[{"{", "}"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<RTNState\>\"", " ", "->", " ", "0"}]}], "\n", "|>"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"defectPopulation", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"createDefect", "[", 
        RowBox[{"1", ",", " ", 
         RowBox[{"{", 
          RowBox[{"7.0", ",", " ", "8.0", ",", " ", "2.6"}], "}"}], ",", " ", 
         RowBox[{"-", "0.018"}], ",", " ", "0.075", ",", " ", "2.0"}], "]"}], 
       ",", "\n", "  ", 
       RowBox[{"createDefect", "[", 
        RowBox[{"2", ",", " ", 
         RowBox[{"{", 
          RowBox[{"14.5", ",", " ", "16.0", ",", " ", "3.8"}], "}"}], ",", 
         " ", 
         RowBox[{"-", "0.030"}], ",", " ", "0.100", ",", " ", "2.5"}], "]"}], 
       ",", "\n", "  ", 
       RowBox[{"createDefect", "[", 
        RowBox[{"3", ",", " ", 
         RowBox[{"{", 
          RowBox[{"22.0", ",", " ", "9.0", ",", " ", "2.2"}], "}"}], ",", " ", 
         RowBox[{"-", "0.012"}], ",", " ", "0.060", ",", " ", "1.8"}], "]"}], 
       ",", "\n", "  ", 
       RowBox[{"createDefect", "[", 
        RowBox[{"4", ",", " ", 
         RowBox[{"{", 
          RowBox[{"19.0", ",", " ", "23.5", ",", " ", "4.2"}], "}"}], ",", 
