         RowBox[{"currentDefects", " ", "=", " ", 
          RowBox[{"result", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}]}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", 
          RowBox[{"Length", "[", "currentHoles", "]"}]}], "}"}]}], "\n", "  ",
        "]"}], ";", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{
       "currentHoles", ",", " ", "currentAnodes", ",", " ", 
        "currentDefects"}], "}"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "Code",
