  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "==="}], " ", "*)"}], "\n", 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"simulateOneRun", "[", "nSteps_Integer", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", "\n", "    ", 
       RowBox[{
        RowBox[{"Q", " ", "=", " ", "Qstate0"}], ",", "\n", "    ", 
        RowBox[{"Qhist", " ", "=", " ", 
         RowBox[{"{", "Qstate0", "}"}]}], ",", "\n", "    ", 
        RowBox[{"holePositions", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ",", "\n", "    ", 
        RowBox[{"finalPositions", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ",", "\n", "    ", 
        RowBox[{"choices", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ",", "\n", "    ", 
        RowBox[{"probHist", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ",", "\n", "    ", 
        RowBox[{"report", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ",", "\n", "    ", "pos", ",", " ", "probs", 
        ",", " ", "picked", ",", " ", "finalPos", ",", " ", 
        "representativeAnodeIndex"}], "\n", "  ", "}"}], ",", "\n", "\n", 
      "  ", 
      RowBox[{
       RowBox[{"Do", "[", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"pos", " ", "=", " ", 
           RowBox[{"sampleGenerationPoint", "[", "]"}]}], ";", "\n", "    ", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"holePositions", ",", " ", "pos"}], "]"}], ";", "\n", "\n",
           "    ", 
          RowBox[{"probs", " ", "=", " ", 
           RowBox[{"landingProbabilities", "[", 
            RowBox[{"pos", ",", " ", "Q"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"probHist", ",", " ", "probs"}], "]"}], ";", "\n", "\n", 
          "    ", 
          RowBox[{"picked", " ", "=", " ", 
           RowBox[{"sampleLanding", "[", 
            RowBox[{"pos", ",", " ", "Q"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"choices", ",", " ", "picked"}], "]"}], ";", "\n", "\n", 
          "    ", 
          RowBox[{"finalPos", " ", "=", " ", 
           RowBox[{"finalHolePosition", "[", 
            RowBox[{"pos", ",", " ", "picked"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"finalPositions", ",", " ", "finalPos"}], "]"}], ";", "\n",
           "\n", "    ", 
          RowBox[{"representativeAnodeIndex", " ", "=", " ", 
           RowBox[{"If", "[", "\n", "      ", 
            RowBox[{
             RowBox[{"picked", " ", "===", " ", "\"\<Loss\>\""}], ",", "\n", 
             "      ", 
             RowBox[{"First", "@", 
              RowBox[{"Ordering", "[", 
               RowBox[{
                RowBox[{"Most", "[", "probs", "]"}], ",", " ", 
                RowBox[{"-", "1"}]}], "]"}]}], ",", "\n", "      ", 
             "picked"}], "\n", "    ", "]"}]}], ";", "\n", "\n", "    ", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"report", ",", "\n", "      ", 
            RowBox[{"<|", "\n", "        ", 
             RowBox[{
              RowBox[{"\"\<Step\>\"", " ", "->", " ", 
               RowBox[{"Length", "[", "choices", "]"}]}], ",", "\n", 
              "        ", 
              RowBox[{"\"\<InitialPosition\>\"", " ", "->", " ", "pos"}], ",",
               "\n", "        ", 
              RowBox[{"\"\<FinalPosition\>\"", " ", "->", " ", "finalPos"}], 
              ",", "\n", "        ", 
              RowBox[{"\"\<Probabilities\>\"", " ", "->", " ", "probs"}], ",",
               "\n", "        ", 
              RowBox[{"\"\<Choice\>\"", " ", "->", " ", "picked"}], ",", "\n",
               "        ", 
              RowBox[{"\"\<QBeforeUpdate\>\"", " ", "->", " ", "Q"}], ",", 
              "\n", "        ", 
              RowBox[{"\"\<PotentialPlot3D\>\"", " ", "->", " ", 
               RowBox[{"potentialPlot3D", "[", 
                RowBox[{
                "Q", ",", " ", "pos", ",", " ", "finalPos", ",", " ", 
                 "picked"}], "]"}]}], ",", "\n", "        ", 
              RowBox[{
              "\"\<RepresentativeProbabilityPlot3D\>\"", " ", "->", " ", 
               RowBox[{"probabilityMap3DForAnode", "[", "\n", "          ", 
                RowBox[{
                "representativeAnodeIndex", ",", " ", "Q", ",", " ", "pos", 
                 ",", " ", "finalPos", ",", " ", "picked"}], "\n", "        ",
                 "]"}]}], ",", "\n", "        ", 
              RowBox[{"\"\<PotentialSlice2D\>\"", " ", "->", " ", 
               RowBox[{"potentialPlotAtDepth", "[", 
                RowBox[{
                 RowBox[{"pos", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], ",", " ", "Q", ",", " ", 
                 "pos", ",", " ", "finalPos"}], "]"}]}], ",", "\n", 
              "        ", 
              RowBox[{"\"\<ProbabilityBarChart\>\"", " ", "->", " ", 
               RowBox[{"barProbabilities", "[", 
                RowBox[{"pos", ",", " ", "Q"}], "]"}]}], ",", "\n", 
              "        ", 
              RowBox[{"\"\<StrengthBar\>\"", " ", "->", " ", 
               RowBox[{"anodeStrengthBar", "[", "Q", "]"}]}]}], "\n", 
             "      ", "|>"}]}], "\n", "    ", "]"}], ";", "\n", "\n", "    ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"picked", " ", "=!=", " ", "\"\<Loss\>\""}], ",", "\n", 
            "      ", 
            RowBox[{
             RowBox[{
              RowBox[{"Q", "[", 
               RowBox[{"[", "picked", "]"}], "]"}], " ", "=", " ", 
              RowBox[{
               RowBox[{"Q", "[", 
                RowBox[{"[", "picked", "]"}], "]"}], " ", "+", " ", "1"}]}], 
             ";"}]}], "\n", "    ", "]"}], ";", "\n", "\n", "    ", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"Qhist", ",", " ", "Q"}], "]"}], ";", "\n", "    ", 
          RowBox[{
           RowBox[{"report", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", "\"\<QAfterUpdate\>\""}], "]"}], 
            "]"}], " ", "=", " ", "Q"}], ";", "\n", "    ", 
          RowBox[{
           RowBox[{"report", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"-", "1"}], ",", " ", "\"\<ChargeBarAfter\>\""}], "]"}],
             "]"}], " ", "=", " ", 
           RowBox[{"chargeBar", "[", "Q", "]"}]}], ";"}], "\n", "    ", ",", 
         "\n", "    ", 
         RowBox[{"{", "nSteps", "}"}]}], "\n", "  ", "]"}], ";", "\n", "\n", 
       "  ", 
       RowBox[{"<|", "\n", "    ", 
        RowBox[{
         RowBox[{"\"\<Report\>\"", " ", "->", " ", "report"}], ",", "\n", 
         "    ", 
         RowBox[{"\"\<HolePositions\>\"", " ", "->", " ", "holePositions"}], 
         ",", "\n", "    ", 
         RowBox[{"\"\<FinalPositions\>\"", " ", "->", " ", "finalPositions"}],
          ",", "\n", "    ", 
         RowBox[{"\"\<Choices\>\"", " ", "->", " ", "choices"}], ",", "\n", 
         "    ", 
         RowBox[{"\"\<ProbabilityHistory\>\"", " ", "->", " ", "probHist"}], 
         ",", "\n", "    ", 
         RowBox[{"\"\<QHistory\>\"", " ", "->", " ", "Qhist"}]}], "\n", "  ", 
        "|>"}]}]}], "\n", "]"}]}], ";"}]}]], "Code",
